rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "luluecom6@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidConfig(data) {
      return hasOnlyAllowedFields(['escalationRules', 'maxImages', 'updatedAt']) &&
             data.escalationRules is list &&
             data.maxImages is number &&
             data.updatedAt is string;
    }

    function isValidAlert(data) {
      return data.orderId is string &&
             data.storeId is string &&
             data.statusTrigger is string;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['name', 'email', 'role', 'updatedAt']) &&
             data.name is string &&
             data.email is string &&
             data.role in ['admin', 'user', 'supervisor', 'manager'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
    }

    // System configuration (Escalation Matrix)
    match /system/config {
      allow read: if true;
      allow write: if isAdmin() && isValidConfig(request.resource.data);
    }
    
    // Real-time Alerts
    match /alerts/{alertId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidAlert(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
