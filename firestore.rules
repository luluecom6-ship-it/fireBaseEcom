rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // isAdmin() has two paths:
    //   PATH A — Custom token (username/password login via /api/auth/token):
    //            The token carries a 'role' claim embedded at token creation time.
    //            No Firestore document lookup needed — avoids chicken-and-egg.
    //   PATH B — Google / email Firebase auth:
    //            No role claim; look up the users/{uid} document instead.
    //   PATH C — Hardcoded admin emails (Google-auth only; email_verified must be true).
    function isAdmin() {
      return isAuthenticated() && (
        // PATH A: custom token with role claim
        request.auth.token.get('role', '') == 'admin' ||
        // PATH B: Firestore document lookup
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        ) ||
        // PATH C: known admin emails (Google / email auth)
        (
          request.auth.token.email in ["luluecom6@gmail.com", "505011@sa.lulumea.com"] &&
          request.auth.token.email_verified == true
        )
      );
    }

    function isSupervisor() {
      return isAuthenticated() && (
        isAdmin() ||
        // Custom token role claim
        request.auth.token.get('role', '') in ['supervisor', 'manager', 'store'] ||
        // Firestore document lookup
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['supervisor', 'manager', 'store']
        )
      );
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() < 100 &&
             data.role in ['admin', 'supervisor', 'picker', 'user', 'manager', 'store', 'driver'] &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('storeId' in data) || (data.storeId is string && data.storeId.size() < 20)) &&
             (!('region' in data) || (data.region is string && data.region.size() < 50));
    }

    function isHeartbeat(data) {
      return data.keys().hasOnly(['lastSeen', 'updatedAt', 'soundAlertsEnabled', 'empId', 'name', 'role', 'storeId', 'email', 'status', 'region']) &&
             data.keys().hasAny(['lastSeen', 'updatedAt']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                      request.auth.uid == userId && 
                      (
                        isValidUser(request.resource.data) || 
                        (request.resource.data.keys().hasAll(['lastSeen']) && request.resource.data.keys().size() <= 5)
                      );
      
      // Admin can update any profile. Users can update their own presence/sound only.
      // Custom-token users (empId == uid) can also update their own full profile.
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (
          request.auth.uid == userId && 
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen', 'soundAlertsEnabled', 'updatedAt']) ||
            (
              isValidUser(request.resource.data) && 
              (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
            )
          )
        )
      );
    }

    // System configuration (Escalation Matrix)
    match /system/config {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // FCM Tokens
    match /fcm_tokens/{userId} {
      allow read: if isSupervisor() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Push Notification Queue — broadcast messages
    match /push_queue/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Real-time Alerts
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // User Presence / Heartbeats
    match /presence/{userId} {
      allow read: if isSupervisor();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
