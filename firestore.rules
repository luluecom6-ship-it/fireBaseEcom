rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "luluecom6@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "505011@sa.lulumea.com")
        );
    }

    function isSupervisor() {
      return isAuthenticated() &&
        (
          isAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supervisor')
        );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isSupervisor() || (isAuthenticated() && request.auth.uid == userId);
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // System configuration (Escalation Matrix)
    match /system/config {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // FCM Tokens
    match /fcm_tokens/{userId} {
      allow read: if isSupervisor() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Push Notification Queue
    match /push_queue/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Real-time Alerts
    match /alerts/{alertId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
